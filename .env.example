# =============================================================================
# Landscaping Design Bot - Environment Variables
# =============================================================================
# Copia questo file in .env e inserisci la tua API key

# OpenRouter API Key
# Ottieni la key da: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# =============================================================================
# Il bot usa Gemini via OpenRouter:
# - Gemini 3 Flash: Chat con l'utente (~$0.0001/msg)
# - Nano Banana Pro: Rendering (~$0.04/immagine)
#
# Costo stimato per demo: $4-8 per 100-200 rendering
# =============================================================================
